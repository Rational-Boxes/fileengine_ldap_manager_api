# FileEngine LDAP Manager — configuration template (copy to .env; never commit .env)
# SPECIFICATION.md §8. LDAP variables are the SAME names the HTTP/WebDAV bridges
# use — so one docker_unified/.env configures all three services identically.

# --- LDAP (shared FILEENGINE_LDAP_*; single-server or master→replica) ---
FILEENGINE_LDAP_ENDPOINT=ldap://openldap:389
FILEENGINE_LDAP_ENDPOINT_REPLICA=          # set for master→replica; empty = single server
FILEENGINE_FAILOVER_COOLDOWN_S=30
FILEENGINE_LDAP_DOMAIN=dc=rationalboxes,dc=com
FILEENGINE_LDAP_BIND_DN=cn=admin,dc=rationalboxes,dc=com   # privileged service bind (writes)
FILEENGINE_LDAP_BIND_PASSWORD=change-me
FILEENGINE_LDAP_USER_BASE=ou=users,dc=rationalboxes,dc=com     # override: users location
FILEENGINE_LDAP_TENANT_BASE=ou=tenants,dc=rationalboxes,dc=com # override: tenants location
LDAP_AVATAR_ATTR=labeledURI                # self-service avatar link attribute (§5.3)

# --- service integrations ---
BRIDGE_URL=http://http-bridge:8090         # token introspection (§2)
BRIDGE_INTROSPECT_TTL=60
REDIS_URL=redis://:redispass@redis:6379/3  # invite + reset tokens
DATABASE_URL=postgresql://fe:fepass@postgres:5432/fileengine  # per-tenant email templates (§5.1)

# --- email / invites / reset (§5) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@rationalboxes.com
INVITE_LINK_BASE=https://app.example.com/set-password
INVITE_TTL_HOURS=72
RESET_LINK_BASE=https://app.example.com/reset-password
RESET_TTL_HOURS=2
RESET_RATE_PER_EMAIL=5                      # reset requests per window, per email
RESET_RATE_PER_IP=20                        # reset requests per window, per source IP
RESET_RATE_WINDOW_S=3600

# --- password policy (§5.4) ---
PW_MIN_LENGTH=12
PW_MAX_LENGTH=128
PW_REQUIRE_UPPER=true
PW_REQUIRE_LOWER=true
PW_REQUIRE_DIGIT=true
PW_REQUIRE_SYMBOL=true
PW_MIN_CLASSES=0                           # >0 → require N of the 4 classes instead
PW_BLOCKLIST=                              # optional path to a forbidden-password list

# --- HTTP (behind the /ldapadmin proxy; monitoring loopback-only) ---
HTTP_HOST=0.0.0.0
HTTP_PORT=8093
HTTP_MONITORING_HOST=127.0.0.1
HTTP_MONITORING_PORT=8094
